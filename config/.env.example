# LLM API (OpenAI-compatible gateway) — required for generation and LLM-as-judge.
# Point these at any OpenAI-compatible endpoint (OpenAI, Azure OpenAI, a local
# server, or a corporate gateway). Offline modes (--no-judge / --evaluate) need none.
LLM_BASE_URL="https://your-openai-compatible-endpoint.example/v1"
LLM_MODEL="your-model-name"
LLM_API_KEY=
